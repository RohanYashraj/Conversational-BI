# Google Gemini API key (required)
GOOGLE_API_KEY=your-key-here

# Optional overrides
BI_GEMINI_MODEL=gemini-3.1-flash-lite
BI_DATA_PATH=./conversational_bi/data/Demo_Policy_Level_Dummy.xlsx
BI_MAX_ROWS=1000
BI_UPLOAD_MAX_BYTES=10485760
BI_SESSION_DB=./bi_sessions.db
BI_REASONING=true
AGENT_OS_HOST=localhost
AGENT_OS_PORT=8000
AGENT_OS_RELOAD=false

# Deployment: extra browser origins allowed to call the API (comma-separated).
# Set this to your deployed UI origin, e.g. https://your-app.vercel.app
BI_CORS_ORIGINS=
